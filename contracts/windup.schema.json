{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://windup.local/contracts/windup.schema.json",
  "title": "Windup product contract",
  "type": "object",
  "required": ["version", "fps", "views", "actions", "imageModels", "generation"],
  "properties": {
    "$schema": { "type": "string" },
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "fps": { "const": 8 },
    "views": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["label", "truth"],
        "properties": { "label": { "type": "string" }, "truth": { "type": "string" } },
        "additionalProperties": false
      }
    },
    "actions": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["label", "type", "loop", "phases"],
        "properties": {
          "label": { "type": "string" },
          "type": { "type": "string" },
          "loop": { "type": "boolean" },
          "phases": { "type": "array", "minItems": 1, "items": { "type": "string" } }
        },
        "additionalProperties": false
      }
    },
    "imageModels": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string" } },
    "generation": {
      "type": "object",
      "required": ["routes", "defaultRoute", "sheet", "starterPack"],
      "properties": {
        "routes": {
          "type": "array",
          "minItems": 2,
          "uniqueItems": true,
          "items": { "enum": ["sheet", "frames"] }
        },
        "defaultRoute": { "enum": ["sheet", "frames"] },
        "sheet": {
          "type": "object",
          "required": ["frameCount", "columns", "rows"],
          "properties": {
            "frameCount": { "const": 8 },
            "columns": { "const": 8 },
            "rows": { "const": 1 }
          },
          "additionalProperties": false
        },
        "starterPack": {
          "type": "object",
          "required": ["view", "actions"],
          "properties": {
            "view": { "type": "string" },
            "actions": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": { "type": "string" }
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
