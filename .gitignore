# Windup Asset Lab — .gitignore

# Secrets & credentials
.env
.env.*
*.key
*.pem
*.p12

# API keys (safety net)
# Any file containing "QNAIGC_KEY" or "api_key" outside of config docs

# Generated data — never commit runtime artifacts
generation-data/
generation-data/*
!/generation-data/.gitkeep

# Backups
generation-data/backups/

# Node
node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
.mypy_cache/
.pytest_cache/

# Cocos Creator
build/
temp/
local/
library/
profiles/
settings/v2/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# OS generated
*.log
*.tmp
*.temp

# Large binary assets (keep only in git-lfs or external storage)
# assets/resources/characters/*/frames/*.png
# assets/textures/**/*.png

# Build output
dist/
out/

# Contract generated files — these ARE committed, but watch for drift
# Note: generated-contract.js, generated-contract.d.ts, generated_contract.py
# are intentionally committed and regenerated from contracts/windup.v1.json

# Reports with screenshots (large)
reports/*.png
reports/*.jpg

# Cache
.agnes/
.cache/
